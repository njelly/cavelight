// Sprite animation library for Cavelight.
// Each entry maps a name to a list of atlas frame indices and a playback speed.
// Frame indices refer to tiles in atlas_8x8.png (512x512, 64x64 grid of 8x8 tiles).
// To add a new animation, add a new entry here — no recompile needed.
{
    // Player
    "player_idle": (frames: [0, 1], fps: 2),

    // NPC characters
    "npc_female": (frames: [64, 65], fps: 2),
    "npc_male": (frames: [128, 129], fps: 2),

    // Friendly
    "cat": (frames: [134, 135], fps: 2),

    // Enemies
    "troll": (frames: [192, 193], fps: 0.8),
    "bat": (frames: [256, 257], fps: 3),
    "skeleton": (frames: [320, 321], fps: 2),
    "rat": (frames: [384, 385], fps: 2.5),

    // Plants
    "flower": (frames: [448, 449], fps: 1.135),
    "flower_patch": (frames: [512, 513], fps: 1.135),

    // Chest
    "chest_closed": (frames: [3], fps: 1),
    "chest_open":   (frames: [4], fps: 1),

    // Signpost
    "signpost": (frames: [136], fps: 1),

    // Campfire
    "campfire": (frames: [75, 76], fps: 8),
    "campfire_smoldering": (frames: [139, 140], fps: 0.4),
    "campfire_extinguished": (frames: [141], fps: 1),

    // Door
    "door_eastwest_closed": (frames: [145], fps: 1),
    "door_eastwest_open": (frames: [209], fps: 1),
    "door_northsouth_closed": (frames: [146], fps: 1),
    "door_northsouth_open": (frames: [210], fps: 1),

    // Ladder
    "ladder_up": (frames: [16], fps: 1),
    "ladder_down": (frames: [15], fps: 1),

    // Spawner
    "spawner_pulse": (frames: [25, 24, 23], fps: 4.0),
    "spawner_source": (frames: [18], fps: 1.0),

    // DirectionArrow
    "direction_arrow_east": (frames: [22], fps: 1),
    "direction_arrow_south": (frames: [20], fps: 1),
    "direction_arrow_west": (frames: [21], fps: 1),
    "direction_arrow_north": (frames: [19], fps: 1),
}
